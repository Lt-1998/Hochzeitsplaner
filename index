const KEY="jenny-nico-premium-v2";
let state;try{state=JSON.parse(localStorage.getItem(KEY))||{tasks:initial,notes:""}}catch(e){state={tasks:initial,notes:""}}
let filter="Alle";const $=id=>document.getElementById(id);
function save(){localStorage.setItem(KEY,JSON.stringify(state))}
function toast(s){const t=$("toast");t.textContent=s;t.classList.add("show");setTimeout(()=>t.classList.remove("show"),1700)}
function fmt(d){return d?new Date(d+"T12:00:00").toLocaleDateString("de-DE"):"ohne Termin"}
function days(date){const n=new Date();n.setHours(0,0,0,0);return Math.ceil((new Date(date+"T00:00:00")-n)/86400000)}
function cats(){return [...new Set(state.tasks.map(t=>t.category))].sort()}
function taskRow(t,canDelete=true){const row=document.createElement("div");row.className="task"+(t.done?" done":"");const cb=document.createElement("input");cb.type="checkbox";cb.className="check";cb.checked=!!t.done;cb.onchange=()=>{t.done=cb.checked;save();render()};const body=document.createElement("div");body.className="body";const title=document.createElement("div");title.className="title";title.textContent=t.title;const meta=document.createElement("div");meta.className="meta";meta.textContent=t.category+" · "+fmt(t.due)+" · "+(t.priority||"mittel");body.append(title,meta);row.append(cb,body);if(canDelete){const del=document.createElement("button");del.className="del";del.textContent="Löschen";del.onclick=()=>{if(confirm("Aufgabe löschen?")){state.tasks=state.tasks.filter(x=>x.id!==t.id);save();render()}};row.appendChild(del)}return row}
function render(){const c=days("2027-05-10"),p=days("2027-05-15");$("civil").textContent=c>=0?c:"vorbei";$("party").textContent=p>=0?p:"vorbei";const total=state.tasks.length,done=state.tasks.filter(t=>t.done).length,pct=Math.round(done/Math.max(total,1)*100);$("allN").textContent=total;$("doneN").textContent=done;$("openN").textContent=total-done;$("pct").textContent=pct+"%";$("ring").style.background=`conic-gradient(var(--rose) ${pct*3.6}deg,#eee3e7 0deg)`;
const next=$("nextList");next.innerHTML="";const upcoming=state.tasks.filter(t=>!t.done).sort((a,b)=>(a.due||"9999").localeCompare(b.due||"9999")).slice(0,4);if(!upcoming.length)next.innerHTML='<div class="empty">Alles erledigt 🎉</div>';upcoming.forEach(t=>{const r=document.createElement("div");r.className="next-item";const d=t.due?new Date(t.due+"T12:00:00"):null;const badge=document.createElement("div");badge.className="badge";badge.innerHTML=d?`<b>${String(d.getDate()).padStart(2,"0")}</b><small>${d.toLocaleString("de-DE",{month:"short"})}</small>`:"<b>–</b><small>offen</small>";const body=document.createElement("div");body.className="body";body.innerHTML='<div class="title"></div><div class="meta"></div>';body.querySelector(".title").textContent=t.title;body.querySelector(".meta").textContent=t.category;r.append(badge,body);next.appendChild(r)});
const maidTasks=state.tasks.filter(t=>t.category==="Trauzeugin"||t.category==="Braut-Notfalltasche");$("maidOpen").textContent=maidTasks.filter(t=>!t.done).length;const maid=$("maidList");maid.innerHTML="";maidTasks.filter(t=>!t.done).slice(0,6).forEach(t=>maid.appendChild(taskRow(t,false)));if(!maid.children.length)maid.innerHTML='<div class="empty">Alles für dich erledigt 🎉</div>';
const f=$("filters");f.innerHTML="";["Alle",...cats()].forEach(c=>{const b=document.createElement("button");b.textContent=c;b.className=c===filter?"active":"";b.onclick=()=>{filter=c;render()};f.appendChild(b)});const list=$("taskList");list.innerHTML="";const shown=state.tasks.filter(t=>filter==="Alle"||t.category===filter).sort((a,b)=>(a.done-b.done)||((a.due||"9999").localeCompare(b.due||"9999")));shown.forEach(t=>list.appendChild(taskRow(t,true)));const sel=$("newCategory");sel.innerHTML="";cats().concat(["Allgemein"]).filter((v,i,a)=>a.indexOf(v)===i).forEach(c=>{const o=document.createElement("option");o.textContent=c;sel.appendChild(o)});$("notesArea").value=state.notes||""}
$("toggleAdd").onclick=()=>$("addBox").classList.toggle("hidden");
$("addTask").onclick=()=>{const title=$("newTitle").value.trim();if(!title){toast("Bitte Aufgabe eingeben");return}state.tasks.push({id:Date.now(),title,category:$("newCategory").value,due:$("newDue").value,done:false,priority:$("newPriority").value});$("newTitle").value="";$("newDue").value="";save();render();toast("Aufgabe hinzugefügt")};
